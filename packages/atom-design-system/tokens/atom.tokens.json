{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "ATOM design tokens — Nirmata Holdings. W3C-style for Figma Variables import. Dark canonical; light values nested under .$extensions.themes.light where applicable.",
  "color": {
    "bg":            { "$type": "color", "$value": "#0b0b0c", "$extensions": { "themes": { "light": "#f4f3ef" } } },
    "surface1":      { "$type": "color", "$value": "#111113", "$extensions": { "themes": { "light": "#ffffff" } } },
    "surface2":      { "$type": "color", "$value": "#161618", "$extensions": { "themes": { "light": "#fbfaf6" } } },
    "surface3":      { "$type": "color", "$value": "#1c1c1f", "$extensions": { "themes": { "light": "#f0eee8" } } },
    "surface4":      { "$type": "color", "$value": "#222226", "$extensions": { "themes": { "light": "#e8e6df" } } },

    "primary":       { "$type": "color", "$value": "#00c8c8", "$extensions": { "themes": { "light": "#007b7b" } } },
    "primaryDim":    { "$type": "color", "$value": "#00989c", "$extensions": { "themes": { "light": "#005f5f" } } },
    "primaryGlow":   { "$type": "color", "$value": "rgba(0,200,200,0.15)", "$extensions": { "themes": { "light": "rgba(0,123,123,0.12)" } } },
    "primaryStrong": { "$type": "color", "$value": "rgba(0,200,200,0.25)", "$extensions": { "themes": { "light": "rgba(0,123,123,0.22)" } } },

    "accentClaude":  { "$type": "color", "$value": "#c084fc" },
    "accentHume":    { "$type": "color", "$value": "#ff7b6b" },
    "accentSamba":   { "$type": "color", "$value": "#f5c842" },
    "accentGpt":     { "$type": "color", "$value": "#74c0fc" },

    "text":          { "$type": "color", "$value": "#e8e8ea", "$extensions": { "themes": { "light": "#14181a" } } },
    "textMuted":     { "$type": "color", "$value": "#8a8a96", "$extensions": { "themes": { "light": "#5b6066" } } },
    "textFaint":     { "$type": "color", "$value": "#4a4a55", "$extensions": { "themes": { "light": "#9aa0a6" } } },

    "border":        { "$type": "color", "$value": "rgba(255,255,255,0.08)", "$extensions": { "themes": { "light": "rgba(20,24,26,0.08)" } } },
    "borderStrong":  { "$type": "color", "$value": "rgba(255,255,255,0.14)", "$extensions": { "themes": { "light": "rgba(20,24,26,0.16)" } } }
  },

  "typography": {
    "fontDisplay": { "$type": "fontFamily", "$value": ["Cabinet Grotesk", "Satoshi", "Inter", "system-ui", "sans-serif"] },
    "fontBody":    { "$type": "fontFamily", "$value": ["Satoshi", "Inter", "system-ui", "sans-serif"] },
    "fontMono":    { "$type": "fontFamily", "$value": ["JetBrains Mono", "SFMono-Regular", "Menlo", "monospace"] },

    "size": {
      "xs":   { "$type": "dimension", "$value": "clamp(0.6875rem, 0.66rem + 0.15vw, 0.75rem)" },
      "sm":   { "$type": "dimension", "$value": "clamp(0.8125rem, 0.78rem + 0.18vw, 0.875rem)" },
      "base": { "$type": "dimension", "$value": "clamp(0.9375rem, 0.9rem + 0.2vw, 1rem)" },
      "md":   { "$type": "dimension", "$value": "clamp(1rem, 0.96rem + 0.25vw, 1.125rem)" },
      "lg":   { "$type": "dimension", "$value": "clamp(1.125rem, 1.06rem + 0.4vw, 1.375rem)" },
      "xl":   { "$type": "dimension", "$value": "clamp(1.375rem, 1.24rem + 0.7vw, 1.75rem)" },
      "2xl":  { "$type": "dimension", "$value": "clamp(1.75rem, 1.5rem + 1.2vw, 2.5rem)" },
      "3xl":  { "$type": "dimension", "$value": "clamp(2.5rem, 1.9rem + 2.6vw, 4rem)" }
    },

    "weight": {
      "light":    { "$type": "fontWeight", "$value": 300 },
      "regular":  { "$type": "fontWeight", "$value": 400 },
      "medium":   { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold":     { "$type": "fontWeight", "$value": 700 },
      "black":    { "$type": "fontWeight", "$value": 800 }
    },

    "leading": {
      "tight":   { "$type": "number", "$value": 1.1 },
      "snug":    { "$type": "number", "$value": 1.25 },
      "normal":  { "$type": "number", "$value": 1.5 },
      "relaxed": { "$type": "number", "$value": 1.65 }
    },

    "tracking": {
      "tight":    { "$type": "dimension", "$value": "-0.02em" },
      "normal":   { "$type": "dimension", "$value": "0em" },
      "wide":     { "$type": "dimension", "$value": "0.04em" },
      "eyebrow":  { "$type": "dimension", "$value": "0.12em" }
    }
  },

  "spacing": {
    "1":  { "$type": "dimension", "$value": "0.25rem" },
    "2":  { "$type": "dimension", "$value": "0.5rem" },
    "3":  { "$type": "dimension", "$value": "0.75rem" },
    "4":  { "$type": "dimension", "$value": "1rem" },
    "5":  { "$type": "dimension", "$value": "1.25rem" },
    "6":  { "$type": "dimension", "$value": "1.5rem" },
    "8":  { "$type": "dimension", "$value": "2rem" },
    "10": { "$type": "dimension", "$value": "2.5rem" },
    "12": { "$type": "dimension", "$value": "3rem" },
    "16": { "$type": "dimension", "$value": "4rem" },
    "20": { "$type": "dimension", "$value": "5rem" },
    "24": { "$type": "dimension", "$value": "6rem" }
  },

  "radius": {
    "sm":   { "$type": "dimension", "$value": "0.375rem" },
    "md":   { "$type": "dimension", "$value": "0.625rem" },
    "lg":   { "$type": "dimension", "$value": "0.875rem" },
    "xl":   { "$type": "dimension", "$value": "1.25rem" },
    "2xl":  { "$type": "dimension", "$value": "1.75rem" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },

  "shadow": {
    "sm": { "$type": "shadow", "$value": "0 1px 2px rgba(0,0,0,0.4)" },
    "md": { "$type": "shadow", "$value": "0 6px 16px rgba(0,0,0,0.45), 0 1px 2px rgba(0,0,0,0.35)" },
    "lg": { "$type": "shadow", "$value": "0 18px 40px rgba(0,0,0,0.55), 0 2px 6px rgba(0,0,0,0.4)" },
    "xl": { "$type": "shadow", "$value": "0 32px 64px rgba(0,0,0,0.6), 0 4px 12px rgba(0,0,0,0.45)" },
    "tealSm": { "$type": "shadow", "$value": "0 0 0 1px rgba(0,200,200,0.18)" },
    "tealMd": { "$type": "shadow", "$value": "0 8px 32px rgba(0,200,200,0.18)" },
    "tealLg": { "$type": "shadow", "$value": "0 16px 48px rgba(0,200,200,0.28)" }
  },

  "motion": {
    "ease": {
      "atom":   { "$type": "cubicBezier", "$value": [0.16, 1, 0.3, 1] },
      "in":     { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] },
      "out":    { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
      "inOut":  { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] }
    },
    "duration": {
      "instant": { "$type": "duration", "$value": "80ms" },
      "fast":    { "$type": "duration", "$value": "120ms" },
      "base":    { "$type": "duration", "$value": "180ms" },
      "slow":    { "$type": "duration", "$value": "320ms" },
      "slower":  { "$type": "duration", "$value": "520ms" },
      "cinema":  { "$type": "duration", "$value": "900ms" }
    },
    "signature": { "$type": "string", "$value": "180ms cubic-bezier(0.16, 1, 0.3, 1)" }
  },

  "brand": {
    "wordmark":      { "$type": "string", "$value": "ΔTOM" },
    "wordmarkRule":  { "$type": "string", "$value": "Δ + T + teal O + M. The first character must always be Unicode Greek Capital Delta (U+0394). Never substitute Latin A." },
    "deltaUnicode":  { "$type": "string", "$value": "U+0394" },
    "logoClearspace":{ "$type": "string", "$value": "Equal to the height of Δ on all sides." },
    "darkCanonical": { "$type": "string", "$value": "#0b0b0c" },
    "lightCanonical":{ "$type": "string", "$value": "#f4f3ef" }
  }
}
