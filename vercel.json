{
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-briefs",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/qa/probe",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/trial-rollover",
      "schedule": "0 9 * * *"
    }
  ]
}
