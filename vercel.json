{
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-briefs",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/qa/probe",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/trial-rollover",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/trial-expiring",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/dnc-scrub",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/consent-renewals",
      "schedule": "0 14 * * 0"
    },
    {
      "path": "/api/atom-ops/cron",
      "schedule": "0 12 * * *"
    }
  ]
}
