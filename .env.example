# ════════════════════════════════════════════════════════════════════
# ATOM OPS — SUPERADMIN DIGITAL WORKER — environment template
# Copy to .env (local) or set in Vercel project settings. NO REAL VALUES HERE.
# All ATOM Ops env access goes through lib/atom-ops/env.ts (getEnv helper).
# ════════════════════════════════════════════════════════════════════

# ── Core platform (already used by the repo) ──────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated superadmin emails. Defaults to ben.oleary@thingktangk.com.
NIRMATA_HQ_EMAILS=ben.oleary@thingktangk.com

# ── Cron / scheduled jobs ─────────────────────────────────────────────
# Vercel sends "Authorization: Bearer <CRON_SECRET>" to cron routes.
# REQUIRED IN PRODUCTION: the ATOM Ops cron route fails closed (HTTP 503) when
# neither CRON_SECRET nor ATOM_OPS_CRON_SECRET is set on a production deploy.
CRON_SECRET=
# Optional alias accepted by the ATOM Ops cron guard when CRON_SECRET is unset.
ATOM_OPS_CRON_SECRET=
# Bearer token real product systems use to POST /api/content/activity-events.
# Falls back to CRON_SECRET / ATOM_OPS_CRON_SECRET when unset. The event-ingest
# route fails closed (HTTP 503) in production when none of these are configured.
CONTENT_EVENTS_INGEST_TOKEN=
# Public base URL of the deployment. Used by the Telegram webhook registrar AND
# as the sole allowed CORS origin for /api/atom-ops/route (credentialed CORS is
# never reflected to arbitrary origins).
ATOM_OPS_PUBLIC_URL=https://your-app.vercel.app

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── GitHub tool ───────────────────────────────────────────────────────
GITHUB_TOKEN=
ATOM_OPS_GITHUB_REPO=BenThingkTangk/antimatter-dominator

# ── Vercel tool ───────────────────────────────────────────────────────
VERCEL_TOKEN=
ATOM_OPS_VERCEL_PROJECT_ID=
ATOM_OPS_VERCEL_TEAM_ID=

# ── Stripe tool ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── Twilio tool ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# TwiML URL used when replaying an outbound call.
ATOM_OPS_TWILIO_REPLAY_TWIML_URL=

# ── Akamai / Linode (GPU compute) tool ────────────────────────────────
LINODE_API_TOKEN=

# ── Sentry / PostHog / Statuspage tool ────────────────────────────────
SENTRY_AUTH_TOKEN=
ATOM_OPS_SENTRY_ORG=
ATOM_OPS_SENTRY_PROJECT=
POSTHOG_API_KEY=
ATOM_OPS_POSTHOG_PROJECT_ID=
ATOM_OPS_POSTHOG_HOST=https://us.posthog.com
ATOM_OPS_STATUSPAGE_API_KEY=
ATOM_OPS_STATUSPAGE_PAGE_ID=

# ── Cloudflare tool ───────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
ATOM_OPS_CLOUDFLARE_ZONE_ID=

# ── Email / Postmark tool ─────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
ATOM_OPS_EMAIL_FROM=ops@yourdomain.com

# ── Telegram bridge ───────────────────────────────────────────────────
ATOM_OPS_TELEGRAM_BOT_TOKEN=
# Secret token sent as X-Telegram-Bot-Api-Secret-Token on every webhook call.
# Generate a long random string and pass it to setWebhook (see ATOM_OPS_README.md).
ATOM_OPS_TELEGRAM_SECRET_TOKEN=
# Only this chat id may issue commands.
ATOM_OPS_TELEGRAM_ALLOWED_CHAT_ID=
